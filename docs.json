{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Request+",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://requestplus.xyz"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/DarkWolfie-YouTube/requestplus"
        }
      ]
    },
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Integrations",
        "icon": "plug",
        "pages": [
          {
            "group": "Music platforms",
            "icon": "music",
            "pages": [
              "integrations/music.mdx",
              "integrations/music/spotify.mdx",
              "integrations/music/youtube-music.mdx",
              "integrations/music/apple-music.mdx",
              "integrations/music/soundcloud.mdx"
            ]
          },
          "integrations/chat.mdx"
        ]
      },
      {
        "group": "Streaming",
        "icon": "tv",
        "pages": [
          "overlay.mdx",
          "queue.mdx"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://github.com/DarkWolfie-YouTube/requestplus/issues"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://requestplus.xyz/downloads"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/DarkWolfie-YouTube/requestplus",
      "website": "https://requestplus.xyz"
    }
  }
}
